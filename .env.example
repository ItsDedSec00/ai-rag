# RAG-Chat Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an

# Server
HTTP_PORT=80

# Admin-Zugang (wird bei Installation gesetzt)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Ollama
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
# GPU-Konfiguration (leer = alle GPUs)
NVIDIA_VISIBLE_DEVICES=all

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# Pfade
KNOWLEDGE_PATH=/data/knowledge
CONFIG_PATH=/data/config

# GitHub (für Auto-Updates)
GITHUB_REPO=dein-username/rag-chat
UPDATE_CHANNEL=stable
