# RAG-Chat — © 2026 David Dülle · https://duelle.org
# Kopiere diese Datei nach .env und passe die Werte an.
#
# WICHTIG: Modell-, RAG- und Chat-Einstellungen (Temperatur, System-Prompt,
# Chunk-Größe etc.) werden über das Admin-Panel verwaltet und in
# /data/config/rag-config.json gespeichert.  Die Werte unten gelten nur
# bei der ERSTINSTALLATION als Startwerte.  Danach hat die gespeicherte
# Config-Datei immer Vorrang.

# ── Server ──
HTTP_PORT=80

# ── Admin-Zugang (wird bei Installation gesetzt) ──
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ── Infrastruktur (werden bei jedem Start gelesen) ──
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
CHROMA_HOST=chromadb
CHROMA_PORT=8000
KNOWLEDGE_PATH=/data/knowledge
CONFIG_PATH=/data/config

# GPU-Konfiguration (leer = alle GPUs)
NVIDIA_VISIBLE_DEVICES=all

# ── Startwerte für Erstinstallation (danach via Admin-Panel) ──
# CHAT_MODEL=llama3.2:1b
# EMBEDDING_MODEL=nomic-embed-text
# TEMPERATURE=0.7
# CONTEXT_WINDOW=4096

# ── GitHub (für Auto-Updates) ──
GITHUB_REPO=ItsDedSec00/ai-rag
UPDATE_CHANNEL=stable

# ── Cloudflare Tunnel (optional) ──
# Ermöglicht sicheren externen Zugriff ohne Port-Weiterleitung.
# Token erhältst du unter: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Nach dem Setzen starten mit: docker compose --profile tunnel up -d
# CLOUDFLARE_TUNNEL_TOKEN=
